# It's a good practice to avoid hardcoding secrets in .env files.
# Instead, use environment variables or a secrets manager.
# For demonstration purposes, let's assume we're using environment variables.
# Uncomment and replace the placeholders with your actual secret values.
DB_USERNAME=
DB_PASSWORD=
API_KEY=
# To set these values as environment variables, you can use the following commands:
# export DB_USERNAME="your_username"
# export DB_PASSWORD="your_password"
# export API_KEY="your_api_key"