# ============================================================
#  NexusGuard AI — Layer 3 & 4 Environment Variables
#
#  NOTE: Most of these are now shared with backend/.env
#  The AI service reads its .env from this directory, OR
#  you can symlink backend/.env here for simplicity.
# ============================================================

# ── Backend / Oracle URL ─────────────────────────────────────
# The main unified backend (port 3000) handles all Oracle routes.
# Update from 3001 → 3000 (the old standalone server is deprecated).
NEXUSGUARD_BACKEND_URL=http://localhost:3000

# ── HMAC Secret ──────────────────────────────────────────────
# Must match WEBHOOK_SECRET in backend/.env
WEBHOOK_SECRET=4275292cbec5bd7023481e3402fbe272ada38572ed51df834cf518adfe1e8f7b

# ── Blockchain ───────────────────────────────────────────────
# Fill in after running: cd ../contracts-hardhat && npm run deploy:amoy
CONTRACT_ADDRESS=
POLYGON_AMOY_RPC_URL=https://rpc-amoy.polygon.technology/
ORACLE_ADDRESS=0xf39Fd6e51aad88F6F4ce6aB8827279cffFb92266

# ── LLM API Keys ─────────────────────────────────────────────
# At least one is required. Gemini is default (free tier available).
GOOGLE_API_KEY=your_google_ai_studio_api_key
OPENAI_API_KEY=your_openai_api_key
GROQ_API_KEY=your_groq_api_key
ANTHROPIC_API_KEY=your_anthropic_api_key

# ── GitHub ───────────────────────────────────────────────────
GITHUB_TOKEN=your_github_personal_access_token

