# It's a good practice to avoid hardcoding secrets in .env files.
# Instead, use environment variables or a secrets manager to store sensitive information.
# For example, you can use a library like 'python-dotenv' to load environment variables from a .env file,
# and then use a secrets manager like 'aws-secretsmanager' to store your secrets.
# 
# To fix this issue, remove the hardcoded secret from this .env.example file.
# If you need to include a placeholder for a secret, use a placeholder value like 'YOUR_SECRET_HERE'.

DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=user
DB_PASSWORD=YOUR_SECRET_HERE
