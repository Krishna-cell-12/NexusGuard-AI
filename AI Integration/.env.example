# It's a good practice to avoid hardcoding secrets in .env files.
# Instead, use environment variables or a secrets manager to store sensitive information.
# For example, you can use a library like 'python-dotenv' to load environment variables from a .env file,
# and then use a secrets manager like 'Hashicorp's Vault' to store and retrieve secrets.
# 
# To fix the issue, remove the hardcoded secret from the .env.example file.
# If you need to store a placeholder value, use a non-sensitive value like 'YOUR_SECRET_KEY_HERE'.

DB_HOST=localhost
DB_PORT=5432
DB_USER=myuser
DB_PASSWORD=YOUR_SECRET_PASSWORD_HERE
SECRET_KEY=YOUR_SECRET_KEY_HERE