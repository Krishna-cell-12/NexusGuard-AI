{
  "name": "nexusguard-ai",
  "version": "1.0.0",
  "description": "Autonomous security scanner — GitHub Webhook receiver + Blockchain Oracle layer.",
  "type": "module",
  "main": "server.js",
  "scripts": {
    "start":            "node --env-file=.env server.js",
    "dev":              "node --env-file=.env --watch server.js",
    "webhook:setup":    "node scripts/setup-webhook.js",
    "install:wsl":      "node $NVM_BIN/../lib/node_modules/npm/bin/npm-cli.js install",
    "contracts:compile":"cd ../contracts-hardhat && npx hardhat compile",
    "contracts:test":   "cd ../contracts-hardhat && npx hardhat test",
    "contracts:deploy:local":  "cd ../contracts-hardhat && npx hardhat run scripts/deploy.js --network hardhat",
    "contracts:deploy:amoy":   "cd ../contracts-hardhat && npx hardhat run scripts/deploy.js --network polygonAmoy"
  },
  "engines": {
    "node": ">=20.6.0"
  },
  "dependencies": {
    "axios":     "^1.9.0",
    "cors":      "^2.8.6",
    "dockerode": "^5.0.0",
    "ethers":    "^6.16.0",
    "express":   "^4.22.2",
    "helmet":    "^7.2.0",
    "morgan":    "^1.11.0",
    "ws":        "^8.18.2"
  }
}

