# ══════════════════════════════════════════════════════════════
#  NexusGuard AI — Unified Environment Variables Example
#  Combines: Core Backend (Yug) + Blockchain Oracle Layer (Yadnesh)
#
#  Instructions:
#    1. Copy this file: cp .env.example .env
#    2. Fill in every value marked with <...>
#    3. NEVER commit .env to source control.
#  Loaded via: node --env-file=.env server.js  (Node ≥ 20.6)
# ══════════════════════════════════════════════════════════════

# ── Server ─────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── GitHub Webhook (Yug's layer) ───────────────────────────────────────────
# Generate: openssl rand -hex 32
# Set the same value in: GitHub Repo → Settings → Webhooks → Secret
GITHUB_WEBHOOK_SECRET=<replace_with_a_long_random_secret>

# ── Orchestrator Service URLs ──────────────────────────────────────────────
# AI patch generation microservice (external)
AI_SERVICE_URL=http://localhost:8000/api/ai/generate-patch

# Web3 bounty trigger — served by THIS server (same process, port 3000)
# No need to change unless you split the services again.
WEB3_SERVICE_URL=http://localhost:3000/api/web3/trigger-bounty

# Optional: HTTP webhook to notify the frontend when no WS clients connected
FRONTEND_WEBHOOK_URL=

# Timeout (ms) for HTTP calls to AI and Web3 services (default: 10000)
HTTP_TIMEOUT_MS=10000

# ── Web3 / Oracle Layer (Yadnesh's layer) ──────────────────────────────────
# Deployer wallet private key (64-char hex, optionally 0x-prefixed)
# ⚠️  Use a dedicated testnet wallet — NEVER your personal mainnet wallet.
PRIVATE_KEY=<your_testnet_private_key>
ORACLE_PRIVATE_KEY=<your_oracle_private_key>  # Same key for hackathon

# Oracle wallet public address (must correspond to ORACLE_PRIVATE_KEY)
ORACLE_ADDRESS=<0x_oracle_wallet_address>

# Deployed NexusGuardBounty contract address (filled by deploy.js after deploy)
CONTRACT_ADDRESS=<0x_deployed_contract_address>

# ── Blockchain RPC URLs ────────────────────────────────────────────────────
# Polygon Amoy Testnet (Chain ID: 80002)
# Public: https://rpc-amoy.polygon.technology/
# Recommended for production: Alchemy / Infura / QuickNode endpoint
POLYGON_AMOY_RPC_URL=https://rpc-amoy.polygon.technology/

# Polygon Mainnet (Chain ID: 137) — production only, real funds!
POLYGON_MAINNET_RPC_URL=https://polygon-rpc.com/

# ── Polygonscan Verification ───────────────────────────────────────────────
# Get your API key at https://polygonscan.com/myapikey
POLYGONSCAN_API_KEY=<your_polygonscan_api_key>

# ── Internal Webhook HMAC ──────────────────────────────────────────────────
# Used by bountyController to verify X-NexusGuard-Signature on external calls
# to POST /api/web3/webhook/merge (NOT used for the internal /trigger-bounty).
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
WEBHOOK_SECRET=<replace_with_a_long_random_secret>

# ── Optional: Gas Reporting ────────────────────────────────────────────────
REPORT_GAS=false
COINMARKETCAP_API_KEY=

# ── System PATH (WSL compatibility) ───────────────────────────────────────
PATH=/home/krishna/.local/bin:/usr/local/bin:/usr/bin:/bin
