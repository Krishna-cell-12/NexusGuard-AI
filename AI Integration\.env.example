# It's a good practice to avoid hardcoding secrets in .env files.
# Instead, use environment variables or a secrets manager to store sensitive information.
# For example, you can use a .env file with placeholders for secrets and provide the actual values when running the application.
# DB_PASSWORD=
# API_KEY=
# To set environment variables, you can use the following command:
# export DB_PASSWORD='your_database_password'
# export API_KEY='your_api_key'