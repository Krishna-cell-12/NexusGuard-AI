# Replace the generic secret with a secure environment variable
# For example, use a hashed version of the secret or a secure key
# stored in a secrets manager.
# 
# Example:
# 
# export SECRET_KEY=$(echo -n 'your_secret_key' | openssl dgst -sha256 | cut -d' ' -f2)
# 
# or
# 
# export SECRET_KEY=$(aws secretsmanager get-secret-value --secret-id your_secret_id --query SecretString --output text)
# 
# Replace 'your_secret_key' and 'your_secret_id' with your actual secret key and secret id
