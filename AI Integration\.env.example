# It's a good practice to avoid hardcoding secrets in .env files.
# Instead, use environment variables or a secrets manager.
# For demonstration purposes, let's assume we have a secret key that needs to be stored securely.

# Create a secrets.json file (not committed to version control) with the following content:
{
  "SECRET_KEY": "your_secret_key_here"
}

# In your application, load the secret from the secrets.json file:
import json
with open('secrets.json') as f:
  secrets = json.load(f)

SECRET_KEY = secrets['SECRET_KEY']