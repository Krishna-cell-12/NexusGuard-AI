# NexusGuard AI — Environment Variables
# Copy this file to .env and fill in real values.
# Never commit .env to source control.
#
# Loaded automatically via `node --env-file=.env` in package.json scripts.
# IMPORTANT: Do NOT duplicate keys — if the same key appears twice,
# only the LAST value wins and the first is silently ignored.

# TCP port for the Express server
PORT=3000

# Secret you configured in:
#   GitHub Repo → Settings → Webhooks → Secret
GITHUB_WEBHOOK_SECRET=replace_with_a_long_random_secret

# ── Orchestrator microservice endpoints ─────────────────────────────────────
AI_SERVICE_URL=http://localhost:8000/api/ai/generate-patch
WEB3_SERVICE_URL=http://localhost:8001/api/web3/trigger-bounty

# Optional: HTTP webhook to notify the frontend when no WS clients are connected
FRONTEND_WEBHOOK_URL=

# Timeout (ms) for calls to AI and Web3 microservices (default: 10000)
HTTP_TIMEOUT_MS=10000
