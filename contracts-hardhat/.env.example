# ENVIRONMENT VARIABLES — NexusGuard AI Backend
# ⚠️  NEVER commit this file to source control!
# Copy this to .env and fill in your real values.

# ── Wallet & Keys ──────────────────────────────────────────
# Deployer wallet private key (hex, 64 chars, optionally 0x-prefixed).
# Used by Hardhat to deploy the contract. May differ from the Oracle wallet.
PRIVATE_KEY=your_deployer_wallet_private_key_here

# The Oracle wallet private key (hex, no 0x prefix required).
# This wallet must be the `oracleAddress` set in the contract.
# Only this key can call releaseBounty() to trigger payouts.
ORACLE_PRIVATE_KEY=0x7e41ef99c164764e4f27785e6eaaba40b5cfa97c40dd43ee5d7d73e1ec206a91

# ── Contract ───────────────────────────────────────────────
# Address of the deployed NexusGuardBounty contract.
CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000

# ── Network ────────────────────────────────────────────────
# Polygon Amoy Testnet (Chain ID: 80002)
POLYGON_AMOY_RPC_URL=https://rpc-amoy.polygon.technology/

# Polygon Mainnet (Chain ID: 137) — for production
POLYGON_MAINNET_RPC_URL=https://polygon-rpc.com/

# ── Polygonscan ────────────────────────────────────────────
# Get from https://polygonscan.com/myapikey (free account)
POLYGONSCAN_API_KEY=S4FPCG8M8JG2HZXX959FA5Q9E1RVXRT72Y

# ── Webhook Security ───────────────────────────────────────
# Random 32-byte hex secret used to sign outgoing webhooks.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
WEBHOOK_SECRET=4275292cbec5bd7023481e3402fbe272ada38572ed51df834cf518adfe1e8f7b

# ── Oracle Deployment ──────────────────────────────────────
# The oracle address to authorize in the contract (usually == deployer for hackathon)
ORACLE_ADDRESS=0x0000000000000000000000000000000000000000

# ── App Config ─────────────────────────────────────────────
NODE_ENV=development
PORT=3001

# ── Optional: Gas Reporting ────────────────────────────────
REPORT_GAS=false
# COINMARKETCAP_API_KEY=your_coinmarketcap_key_here
